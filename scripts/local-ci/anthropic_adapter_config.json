{
  "suite_version": 1,
  "litellm_base_url": "http://127.0.0.1:4001",
  "langfuse_query_url": "http://127.0.0.1:3000",
  "langfuse_public_key_env": "LANGFUSE_PUBLIC_KEY",
  "langfuse_secret_key_env": "LANGFUSE_SECRET_KEY",
  "cases": {
    "claude_adapter_gpt54": {
      "command": [
        "claude",
        "-p",
        "Reply with exactly two words: harness smoke",
        "--output-format",
        "json",
        "--model",
        "gpt-5.4",
        "--permission-mode",
        "bypassPermissions",
        "--allowedTools",
        ""
      ],
      "env": {
        "ANTHROPIC_BASE_URL": "http://127.0.0.1:4001/anthropic"
      },
      "required_trace_names": [
        "claude-code.orchestrator"
      ],
      "expected_user_ids": [
        "litellm.fork"
      ],
      "expected_trace_environment": "dev",
      "require_trace_session_id": true,
      "match_trace_session_id_from_stdout": true,
      "require_trace_ids_distinct_from_session_ids": true,
      "post_run_wait_seconds": 2,
      "allowed_generation_routes": [
        "/anthropic/v1/messages"
      ],
      "required_trace_tags": [
        "route:anthropic_messages",
        "route:anthropic_openai_responses_adapter",
        "anthropic-openai-responses-adapter",
        "anthropic-adapter-model:gpt-5.4",
        "anthropic-adapter-target:/v1/responses"
      ],
      "required_trace_tag_prefixes": [
        "anthropic-billing-header-key:cc_version",
        "anthropic-billing-header-key:cc_entrypoint",
        "claude-effort:",
        "thinking-type:"
      ],
      "required_generation_metadata_truthy": [
        "anthropic_adapter_model",
        "anthropic_adapter_original_model",
        "anthropic_adapter_target_endpoint",
        "passthrough_route_family"
      ],
      "request_payload_checks": {
        "required_paths": [
          "model",
          "input",
          "instructions",
          "reasoning.effort",
          "stream"
        ]
      },
      "command_json_checks": {
        "required_equals": {
          "is_error": false,
          "result": "harness smoke"
        },
        "required_minimums": {
          "usage.input_tokens": 1,
          "usage.output_tokens": 1,
          "total_cost_usd": 1e-06
        }
      },
      "session_history_validation": {
        "db_host": "127.0.0.1",
        "db_port": 5434,
        "db_name": "aawm_tristore",
        "db_user": "aawm",
        "db_password_env": "AAWM_DB_PASSWORD",
        "expected_provider": "openai",
        "expected_model": "gpt-5.4",
        "minimums": {
          "input_tokens": 1,
          "output_tokens": 1,
          "total_tokens": 1,
          "response_cost_usd": 1e-06
        }
      },
      "timeout_seconds": 180,
      "langfuse_poll_timeout_seconds": 60,
      "runtime_postconditions": {
        "healthcheck_url": "http://127.0.0.1:4001/health/liveliness",
        "docker_container_name": "litellm-dev"
      }
    },
    "claude_adapter_peeromega_fanout": {
      "command": [
        "claude",
        "-p",
        "Dispatch to the following agents and have them all report back the current time and do nothing else at all: analyst, data, gpt-5-3-codex-spark, gpt-5-4, gemini-3-flash-preview, gemini-3-1-pro-preview, gemini-3-1-flash-lite-preview, elephant-alpha.",
        "--output-format",
        "json",
        "--permission-mode",
        "bypassPermissions"
      ],
      "env": {
        "ANTHROPIC_BASE_URL": "http://127.0.0.1:4001/anthropic"
      },
      "required_trace_names": [
        "claude-code.orchestrator"
      ],
      "expected_user_ids": [
        "litellm.fork"
      ],
      "expected_trace_environment": "dev",
      "require_trace_session_id": true,
      "match_trace_session_id_from_stdout": true,
      "require_trace_ids_distinct_from_session_ids": true,
      "post_run_wait_seconds": 2,
      "allowed_generation_routes": [
        "/anthropic/v1/messages"
      ],
      "required_trace_tags": [
        "route:anthropic_messages"
      ],
