        "anthropic-billing-header-key:cc_version",
        "anthropic-billing-header-key:cc_entrypoint"
      ],
      "command_json_checks": {
        "required_equals": {
          "is_error": false
        },
        "required_minimums": {
          "total_cost_usd": 1e-06
        }
      },
      "session_history_validation": {
        "db_host": "127.0.0.1",
        "db_port": 5434,
        "db_name": "aawm_tristore",
        "db_user": "aawm",
        "db_password_env": "AAWM_DB_PASSWORD",
        "expected_rows": [
          {
            "provider": "anthropic",
            "model": "claude-opus-4-7",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1
            }
          },
          {
            "provider": "anthropic",
            "model": "claude-haiku-4-5-20251001",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1
            }
          },
          {
            "provider": "anthropic",
            "model": "claude-sonnet-4-6",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1
            }
          },
          {
            "provider": "openai",
            "model": "gpt-5.4",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1,
              "response_cost_usd": 1e-06
            }
          },
          {
            "provider": "openai",
            "model": "gpt-5.3-codex-spark",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1,
              "response_cost_usd": 1e-06
            }
          },
          {
            "provider": "gemini",
            "model": "gemini-3.1-pro-preview",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1,
              "response_cost_usd": 1e-06
            }
          },
          {
            "provider": "gemini",
            "model": "gemini-3-flash-preview",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1,
              "response_cost_usd": 1e-06
            }
          },
          {
            "provider": "gemini",
            "model": "gemini-3.1-flash-lite-preview",
            "minimums": {
              "input_tokens": 1,
              "output_tokens": 1,
              "response_cost_usd": 1e-06
            }
          }
        ]
      },
      "runtime_postconditions": {
        "healthcheck_url": "http://127.0.0.1:4001/health/liveliness",
        "docker_container_name": "litellm-dev"
      },
      "timeout_seconds": 240,
      "langfuse_poll_timeout_seconds": 90
    },
