# Tristore DB
AAWM_DB_HOST = localhost
AAWM_DB_PORT = 5434
AAWM_DB_NAME = aawm_tristore
AAWM_DB_USER = aawm
AAWM_DB_PWD = your_aawm_db_password
AAWM_DB_SSLMODE = disable
# Keep this direct until the shared PgBouncer endpoint is verified live.
# After verification, use the PgBouncer runtime endpoint here and keep
# AAWM_DIRECT_DATABASE_URL on the direct Postgres endpoint for admin/backfills.
AAWM_DATABASE_URL = "postgresql://aawm:your_aawm_db_password@localhost:5434/aawm_tristore?application_name=aawm-litellm-session-history"
AAWM_DIRECT_DATABASE_URL = "postgresql://aawm:your_aawm_db_password@localhost:5434/aawm_tristore"
AAWM_SESSION_HISTORY_DB_APPLICATION_NAME = aawm-litellm-session-history
AAWM_SESSION_HISTORY_STATEMENT_CACHE_SIZE = 0
AAWM_PROVIDER_STATUS_DB_APPLICATION_NAME = aawm-provider-status-observations
