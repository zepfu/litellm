# Development Configs
LITELLM_MASTER_KEY = "sk-1234"
DATABASE_URL = "postgresql://llmproxy:dbpassword9090@db:5432/litellm"
STORE_MODEL_IN_DB = "True"


# Tristore DB
# Runtime traffic uses the shared PgBouncer endpoint. Maintenance, schema, and
# backfill scripts should use AAWM_DIRECT_DATABASE_URL or an explicit --pg-dsn.
AAWM_DB_HOST = 127.0.0.1
AAWM_DB_PORT = 6432
AAWM_DB_NAME = aawm_tristore
AAWM_DB_USER = aawm
AAWM_DB_PWD = your_aawm_db_password
AAWM_DB_SSLMODE = disable
AAWM_DATABASE_URL = "postgresql://aawm:your_aawm_db_password@127.0.0.1:6432/aawm_tristore?application_name=aawm-litellm-session-history"
AAWM_DIRECT_DATABASE_URL = "postgresql://aawm:your_aawm_db_password@127.0.0.1:5434/aawm_tristore"
AAWM_SESSION_HISTORY_DB_APPLICATION_NAME = aawm-litellm-session-history
AAWM_SESSION_HISTORY_STATEMENT_CACHE_SIZE = 0
AAWM_DYNAMIC_INJECTION_DB_APPLICATION_NAME = aawm-litellm-dynamic-injection
PGAPPNAME = aawm-litellm-runtime
AAWM_PROVIDER_STATUS_DB_APPLICATION_NAME = aawm-provider-status-observations
AAWM_PROVIDER_STATUS_SETUP_SCHEMA_ON_START = 0
