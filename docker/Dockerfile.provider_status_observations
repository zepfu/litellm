FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    AAWM_LITELLM_ENVIRONMENT=dev \
    AAWM_PROVIDER_STATUS_APPLY=1 \
    AAWM_PROVIDER_STATUS_INTERVAL_SECONDS=300 \
    AAWM_PROVIDER_STATUS_TIMEOUT=2 \
    AAWM_PROVIDER_STATUS_PING_COUNT=1 \
    AAWM_PROVIDER_STATUS_PING_TIMEOUT=2 \
    AAWM_PROVIDER_STATUS_SKIP_ICMP=0 \
    AAWM_PROVIDER_STATUS_SETUP_SCHEMA_ON_START=1 \
    AAWM_PROVIDER_STATUS_DB_LOCK_TIMEOUT_MS=1000 \
    AAWM_PROVIDER_STATUS_DB_STATEMENT_TIMEOUT_MS=5000

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        iputils-ping \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir "psycopg[binary]==3.3.4"

COPY scripts/record_provider_status_observations.py /app/scripts/record_provider_status_observations.py
COPY scripts/grok_oidc_refresh.py /app/scripts/grok_oidc_refresh.py
COPY scripts/antigravity_oauth_refresh.py /app/scripts/antigravity_oauth_refresh.py
COPY scripts/codex_oauth_refresh.py /app/scripts/codex_oauth_refresh.py
COPY scripts/xai_oauth_refresh.py /app/scripts/xai_oauth_refresh.py
COPY scripts/run_provider_status_observations_loop.py /app/scripts/run_provider_status_observations_loop.py
RUN touch /app/scripts/__init__.py

ENTRYPOINT ["python", "/app/scripts/run_provider_status_observations_loop.py"]
